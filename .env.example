# ============================================================
# .env.example — 複製為 .env 並填入實際值（本機開發用）
# 生產環境變數由 Cloud Run 注入，不需要此檔案
# ============================================================

# GCP
GCP_PROJECT_ID=stock-decision-assistant
GCP_REGION=asia-east1

# 本機開發時，指向 service account key 檔案路徑
# 生產環境 (Cloud Run) 使用 ADC，不需要此變數
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Server
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# ── 數據源 API Keys ─────────────────────────────────────────
# 台股 OHLCV：優先使用 TWSE 官方 API（免費、免 key）
# 美股 OHLCV：Yahoo Finance → Alpha Vantage fallback
# Quote 即時報價：Yahoo Finance（免費，有 rate limit）

# FINMIND_API_TOKEN=         # FinMind 台股 API（可選，免費版每小時 600 次）
#                             # 申請：https://finmindtrade.com

# ALPHA_VANTAGE_KEY=         # Alpha Vantage 美股 fallback（可選）
#                             # 免費版：25 次/日，付費版不限
#                             # 申請：https://www.alphavantage.co/support/#api-key
#                             # 設置後自動作為 Yahoo Finance 的備援
