{
  "name": "quant-trading",
  "version": "0.1.0",
  "private": true,
  "description": "Personal quantitative trading platform - TW & US stocks",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev -w packages/client",
    "dev:server": "npm run dev -w packages/server",
    "build": "npm run build -w packages/shared && npm run build -w packages/client && npm run build -w packages/server",
    "build:client": "npm run build -w packages/client",
    "build:server": "npm run build -w packages/server",
    "start": "npm run start -w packages/server",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "test": "npm run test --workspaces --if-present",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
